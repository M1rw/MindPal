{
  "version": 2,
  "buildCommand": "pip install -r requirements.txt",
  "env": {
    "ENVIRONMENT": "production",
    "DEBUG": "false",
    "ENABLE_DOCS": "false",
    "ENABLE_HSTS": "true",
    "FIREBASE_USE_APPLICATION_DEFAULT": "false",
    "PYTHONUNBUFFERED": "1"
  },
  "functions": {
    "api/index.py": {
      "memory": 3008,
      "maxDuration": 30,
      "runtime": "python3.12"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/app/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/ui",
      "dest": "/api/index.py"
    },
    {
      "src": "/docs(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/redoc(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/openapi.json",
      "dest": "/api/index.py"
    },
    {
      "src": "/",
      "dest": "/api/index.py"
    }
  ],
  "outputDirectory": ".",
  "framework": "python"
}
