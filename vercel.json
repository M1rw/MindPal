{
  "version": 2,
  "buildCommand": "pip install -r requirements.txt",
  "env": {
    "ENVIRONMENT": "production",
    "DEBUG": "false",
    "ENABLE_DOCS": "false",
    "ENABLE_HSTS": "true",
    "FIREBASE_USE_APPLICATION_DEFAULT": "false"
  },
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "memory": 3008,
      "runtime": "python3.12"
    }
  }
}