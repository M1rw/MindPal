ENABLE_MESSAGE_CONTENT_INTENT=true
# HUGGING FACE #
HF_API_TOKEN=hf_xxx
HF_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.3
# GOOGLE #
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash-preview-09-2025
