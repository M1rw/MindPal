# .env.example

# -----------------------------------------------------------------------------
# MindPal environment
# -----------------------------------------------------------------------------

APP_NAME=MindPal
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
ENABLE_DOCS=true
ENABLE_HSTS=false

# Public app URL, used by providers like OpenRouter for optional attribution.
APP_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

HOST=0.0.0.0
PORT=8000
WORKERS=1

# Comma-separated.
TRUSTED_HOSTS=*

# Comma-separated.
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# Backward-compatible alias if config.py uses this name.
CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# LLM provider order
# -----------------------------------------------------------------------------
# Supported: gemini,openrouter,groq
# Offline deterministic fallback is always owned by LLMService.
# It is not configured here.
LLM_PROVIDER_ORDER=gemini,openrouter,groq
# Safety classifier behavior
ENABLE_LLM_SAFETY_CLASSIFIER=true
ALLOW_OFFLINE_LLM_SAFETY_CLASSIFIER=false

# -----------------------------------------------------------------------------
# Gemini
# -----------------------------------------------------------------------------
# Uses REST generateContent API.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_SECONDS=45

# -----------------------------------------------------------------------------
# OpenRouter
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=45
OPENROUTER_APP_URL=http://localhost:8000
OPENROUTER_APP_TITLE=MindPal

# -----------------------------------------------------------------------------
# Groq
# -----------------------------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# Firebase Auth + Firestore
# -----------------------------------------------------------------------------
# Use one of:
# 1. GOOGLE_APPLICATION_CREDENTIALS / FIREBASE_CREDENTIALS_PATH
# 2. FIREBASE_CREDENTIALS_JSON
# 3. Application Default Credentials in cloud runtime
FIREBASE_PROJECT_ID=
GOOGLE_CLOUD_PROJECT=

FIREBASE_CREDENTIALS_PATH=
GOOGLE_APPLICATION_CREDENTIALS=

# JSON string. Keep empty locally unless needed.
FIREBASE_CREDENTIALS_JSON=
FIRESTORE_DATABASE_ID=default

FIREBASE_APP_NAME=mindpal
FIREBASE_USE_APPLICATION_DEFAULT=true
FIREBASE_CHECK_REVOKED_TOKENS=false

# -----------------------------------------------------------------------------
# TTS provider order
# -----------------------------------------------------------------------------
# Supported external provider: camb
# Browser fallback is always owned by TTSService.
TTS_PROVIDER_ORDER=camb

# -----------------------------------------------------------------------------
# Camb.ai TTS
# -----------------------------------------------------------------------------
CAMB_API_KEY=
CAMB_BASE_URL=https://client.camb.ai/apis
CAMB_SPEECH_MODEL=mars-8.1-flash-beta
CAMB_DEFAULT_VOICE_ID=147320
CAMB_TIMEOUT_SECONDS=45
CAMB_APPLY_ENHANCEMENT=

# -----------------------------------------------------------------------------
# Memory
# -----------------------------------------------------------------------------
MEMORY_SUMMARY_MAX_CHARS=4000

# -----------------------------------------------------------------------------
# Safety / RAG
# -----------------------------------------------------------------------------
# These are file-backed in the repo:
# backend/safety/*.yaml
# backend/rag/corpus/*.yaml
SAFETY_ENABLED=true
RAG_ENABLED=true

# -----------------------------------------------------------------------------
# Development
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO