# -----------------------------------------------------------------------------
# MindPal environment
# -----------------------------------------------------------------------------

APP_NAME=MindPal
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
ENABLE_DOCS=true
ENABLE_HSTS=false
APP_URL=http://localhost:8000
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

HOST=0.0.0.0
PORT=8000
WORKERS=1

TRUSTED_HOSTS=*
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*
CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# Auth/session policy
# -----------------------------------------------------------------------------

ALLOW_ANONYMOUS_SESSIONS=true

# -----------------------------------------------------------------------------
# LLM providers
# Supported: gemini,openrouter,groq
# -----------------------------------------------------------------------------

LLM_PROVIDER_ORDER=gemini,openrouter,groq

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_SECONDS=45

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=45
OPENROUTER_APP_URL=http://localhost:8000
OPENROUTER_APP_TITLE=MindPal

GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=30

# LLM fallback policy
REQUIRE_REMOTE_LLM_PROVIDER=false
ENABLE_OFFLINE_LLM_FALLBACK=true
ALLOW_OFFLINE_LLM_IN_PRODUCTION=false

# -----------------------------------------------------------------------------
# Firebase Admin / Firestore
# Backend uses Firebase Admin SDK, not frontend Firebase client config.
# Use FIREBASE_CREDENTIALS_JSON for Vercel.
# Use FIREBASE_CREDENTIALS_PATH locally if preferred.
# -----------------------------------------------------------------------------

FIREBASE_PROJECT_ID=
GOOGLE_CLOUD_PROJECT=

FIREBASE_CREDENTIALS_JSON=
FIREBASE_CREDENTIALS_PATH=
GOOGLE_APPLICATION_CREDENTIALS=

FIRESTORE_DATABASE_ID=default
FIREBASE_APP_NAME=mindpal
FIREBASE_USE_APPLICATION_DEFAULT=false
FIREBASE_CHECK_REVOKED_TOKENS=false

# -----------------------------------------------------------------------------
# TTS
# Supported external provider: camb
# Browser fallback is owned by TTSService.
# -----------------------------------------------------------------------------

TTS_PROVIDER_ORDER=camb

CAMB_API_KEY=
CAMB_BASE_URL=https://client.camb.ai/apis
CAMB_SPEECH_MODEL=mars-8.1-flash-beta
CAMB_DEFAULT_VOICE_ID=147320
CAMB_TIMEOUT_SECONDS=45
CAMB_APPLY_ENHANCEMENT=false

REQUIRE_EXTERNAL_TTS_PROVIDER=false
ENABLE_BROWSER_TTS_FALLBACK=true
ALLOW_BROWSER_TTS_IN_PRODUCTION=true
TTS_TIMEOUT_SECONDS=20

# -----------------------------------------------------------------------------
# Memory
# -----------------------------------------------------------------------------

MEMORY_SUMMARY_MAX_CHARS=4000
ENABLE_LLM_MEMORY_SUMMARIZATION=true
ALLOW_OFFLINE_LLM_MEMORY_SUMMARIZATION=false

# -----------------------------------------------------------------------------
# Safety
# -----------------------------------------------------------------------------

SAFETY_ENABLED=true
ENABLE_LLM_SAFETY_CLASSIFIER=true
ALLOW_OFFLINE_LLM_SAFETY_CLASSIFIER=false

ENABLE_PERSPECTIVE=false
PERSPECTIVE_API_KEY=

# -----------------------------------------------------------------------------
# Output guard
# -----------------------------------------------------------------------------

ENABLE_LLM_OUTPUT_REWRITE=true
ALLOW_OFFLINE_LLM_OUTPUT_REWRITE=false

# -----------------------------------------------------------------------------
# RAG
# -----------------------------------------------------------------------------

RAG_ENABLED=true
ENABLE_LLM_RAG_PLANNING=true
ENABLE_BUILTIN_RAG_FALLBACK=false
ALLOW_BUILTIN_RAG_FALLBACK_IN_PRODUCTION=false
ALLOW_OFFLINE_LLM_RAG_PLANNER=false

# -----------------------------------------------------------------------------
# Cloudflare Workers AI through AI Gateway
# -----------------------------------------------------------------------------
# Set LLM_PROVIDER_ORDER=cloudflare,openrouter,groq,gemini if you want Cloudflare first.
CF_AIG_TOKEN=
CLOUDFLARE_ACCOUNT_ID=665a8598994b2099ff235fc3779e7531
CLOUDFLARE_GATEWAY_ID=default
CLOUDFLARE_MODEL=workers-ai/@cf/meta/llama-3.1-8b-instruct-fp8-fast
CLOUDFLARE_AI_MODE=gateway_compat
