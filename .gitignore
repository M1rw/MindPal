# .gitignore

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# Virtual envs
.venv/
venv/
env/
ENV/

# Environment / secrets
.env
.env.*
!.env.example
secrets/
*.pem
*.key
*.crt
*service-account*.json
firebase-service-account.json

# Firebase / Google credentials
google-application-credentials.json
application_default_credentials.json

# Node / frontend
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Logs
logs/
*.log

# Runtime data
tmp/
temp/
.cache/

# MindPal generated/local state
var/
local_data/
secrets/firebase-service-account.json
